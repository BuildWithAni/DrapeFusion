# DrapeFusion root .gitignore

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# python
venv/
.python/
__pycache__/
*.pyc

# env files
.env*
!.env.example

# next.js
.next/
out/

# production
/build

# misc
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# model checkpoints & weights (too large for git — download separately)
ckpt/
ckpts/
densepose/
detectron2/
ip_adapter/
.huggingface/
.cache/

# large model binary files
*.bin
*.safetensors
*.onnx
*.pkl
*.pth
